<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- 欢迎模式 -->
    <LinearLayout
        android:id="@+id/layoutWelcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎光临"
            android:textColor="@color/white"
            android:textSize="72sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="海邻到家便利店"
            android:textColor="@color/text_secondary"
            android:textSize="36sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <!-- 等待付款模式 -->
    <LinearLayout
        android:id="@+id/layoutWaiting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="应付金额"
            android:textColor="@color/text_secondary"
            android:textSize="36sp"/>

        <TextView
            android:id="@+id/textAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥0.00"
            android:textColor="@color/text_amount"
            android:textSize="96sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请扫码支付"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:layout_marginTop="32dp"/>
    </LinearLayout>

    <!-- 付款成功模式 -->
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="付款成功"
            android:textColor="@color/success"
            android:textSize="72sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textPaidAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¥0.00"
            android:textColor="@color/text_amount"
            android:textSize="64sp"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <!-- 付款失败模式 -->
    <LinearLayout
        android:id="@+id/layoutFailed"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="付款失败"
            android:textColor="@color/error"
            android:textSize="72sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请重试"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <!-- 二维码模式 -->
    <LinearLayout
        android:id="@+id/layoutQRCode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imageQRCode"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请使用微信/支付宝扫码支付"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <!-- 谢谢惠顾模式 -->
    <LinearLayout
        android:id="@+id/layoutThankYou"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="谢谢惠顾"
            android:textColor="@color/accent"
            android:textSize="80sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎您再次光临"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="海邻到家便利店"
            android:textColor="@color/text_secondary"
            android:textSize="28sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</FrameLayout>
