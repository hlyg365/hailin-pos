{
  "name": "hailin-pos-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "海邻到家 - 统一跨端架构 monorepo",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @hailin/pos-app dev",
    "dev:dashboard": "pnpm --filter @hailin/dashboard dev",
    "dev:assistant": "pnpm --filter @hailin/assistant dev",
    "build": "pnpm -r build",
    "build:pos": "pnpm --filter @hailin/pos-app build",
    "build:dashboard": "pnpm --filter @hailin/dashboard build",
    "build:assistant": "pnpm --filter @hailin/assistant build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
