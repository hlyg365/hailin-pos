# 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置信息

# ==================== 小程序配置 ====================
# 微信小程序AppID（从微信公众平台获取）
WECHAT_APP_ID=your_wechat_app_id_here

# 微信小程序AppSecret（从微信公众平台获取）
WECHAT_APP_SECRET=your_wechat_app_secret_here

# ==================== 微信支付配置 ====================
# 微信支付商户号（从微信支付商户平台获取）
WECHAT_MCH_ID=your_wechat_mch_id_here

# 微信支付API密钥（32位字符串，从商户平台设置）
WECHAT_MCH_KEY=your_wechat_mch_key_here

# 微信支付证书路径（绝对路径）
WECHAT_MCH_CERT_PATH=/path/to/your/cert.p12

# 微信支付证书密码（商户号）
WECHAT_MCH_CERT_PASSWORD=your_wechat_mch_id_here

# ==================== 数据库配置 ====================
# PostgreSQL数据库连接URL
DATABASE_URL=postgresql://hailin_user:your_password@localhost:5432/hailin

# 数据库用户名
DB_USER=hailin_user

# 数据库密码
DB_PASSWORD=your_password

# 数据库名称
DB_NAME=hailin

# 数据库主机
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# ==================== 服务器配置 ====================
# 服务器基础URL（必须使用HTTPS）
BASE_URL=https://api.hailin.com

# 服务器端口
PORT=5000

# 节点环境（development/production）
NODE_ENV=production

# ==================== JWT配置 ====================
# JWT密钥（随机字符串，用于token签名）
JWT_SECRET=your_random_jwt_secret_key_here_min_32_characters

# JWT过期时间（小时）
JWT_EXPIRES_IN=720

# ==================== 对象存储配置 ====================
# AWS访问密钥ID（或阿里云AccessKey ID）
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here

# AWS访问密钥Secret（或阿里云AccessKey Secret）
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# AWS区域（如：cn-hangzhou, ap-southeast-1）
AWS_REGION=cn-hangzhou

# S3存储桶名称
AWS_BUCKET=hailin-images

# ==================== 短信服务配置（可选）====================
# 短信服务AccessKey ID（阿里云或腾讯云）
SMS_ACCESS_KEY_ID=your_sms_access_key_id_here

# 短信服务AccessKey Secret
SMS_ACCESS_KEY_SECRET=your_sms_access_key_secret_here

# 短信签名名称
SMS_SIGN_NAME=海邻到家

# 短信模板代码（验证码）
SMS_TEMPLATE_CODE_CODE=SMS_123456789

# 短信模板代码（订单通知）
SMS_TEMPLATE_CODE_ORDER=SMS_123456790

# ==================== Redis配置（可选）====================
# Redis主机
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis密码
REDIS_PASSWORD=your_redis_password_here

# Redis数据库编号
REDIS_DB=0

# ==================== 日志配置 ====================
# 日志级别（error/warn/info/debug）
LOG_LEVEL=info

# 日志目录
LOG_DIR=/app/work/logs

# ==================== 第三方服务配置（可选）====================
# 七牛云AK（如果使用七牛云）
QINIU_AK=your_qiniu_ak_here

# 七牛云SK（如果使用七牛云）
QINIU_SK=your_qiniu_sk_here

# 七牛云Bucket
QINIU_BUCKET=hailin-images

# ==================== 其他配置 ====================
# 应用名称
APP_NAME=海邻到家

# 应用版本
APP_VERSION=1.0.0

# 时区
TZ=Asia/Shanghai

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# 分页默认大小
DEFAULT_PAGE_SIZE=20

# 支付超时时间（分钟）
PAYMENT_TIMEOUT=30

# 订单自动取消时间（分钟）
ORDER_CANCEL_TIMEOUT=30

# 接龙自动结束时间（小时）
CHAIN_AUTO_END_HOURS=24

# ==================== 开发环境专用（生产环境删除）====================
# 是否启用Mock数据
ENABLE_MOCK_DATA=false

# 是否启用调试模式
DEBUG=false

# 是否启用热更新
HMR=true

# ==================== 监控配置（可选）====================
# Sentry DSN（错误监控）
SENTRY_DSN=your_sentry_dsn_here

# 阿里云日志服务Endpoint
ALIYUN_LOG_ENDPOINT=https://cn-hangzhou.log.aliyuncs.com

# 阿里云日志服务AccessKey
ALIYUN_LOG_ACCESS_KEY=your_aliyun_log_access_key_here

# 阿里云日志服务AccessKeySecret
ALIYUN_LOG_ACCESS_KEY_SECRET=your_aliyun_log_access_key_secret_here

# ==================== CDN配置（可选）====================
# CDN域名
CDN_DOMAIN=https://cdn.hailin.com

# CDN加速域名前缀
CDN_PREFIX=/static

# ==================== 邮件服务配置（可选）====================
# SMTP主机
SMTP_HOST=smtp.exmail.qq.com

# SMTP端口
SMTP_PORT=465

# SMTP用户名
SMTP_USER=your_email@example.com

# SMTP密码
SMTP_PASSWORD=your_email_password_here

# 发件人
SMTP_FROM=noreply@hailin.com

# ==================== 地图服务配置（可选）====================
# 高德地图API Key
AMAP_API_KEY=your_amap_api_key_here

# 百度地图API Key
BAIDU_MAP_API_KEY=your_baidu_map_api_key_here

# ==================== 微信公众号配置（可选）====================
# 微信公众号AppID
WECHAT_MP_APP_ID=your_wechat_mp_app_id_here

# 微信公众号AppSecret
WECHAT_MP_APP_SECRET=your_wechat_mp_app_secret_here

# 微信公众号Token
WECHAT_MP_TOKEN=your_wechat_mp_token_here

# 微信公众号EncodingAESKey
WECHAT_MP_ENCODING_AES_KEY=your_wechat_mp_encoding_aes_key_here

# ==================== 面试码配置（可选）====================
# 支付宝AppID
ALIPAY_APP_ID=your_alipay_app_id_here

# 支付宝私钥（RSA2）
ALIPAY_PRIVATE_KEY=your_alipay_private_key_here

# 支付宝公钥
ALIPAY_PUBLIC_KEY=your_alipay_public_key_here

# 支付宝回调地址
ALIPAY_NOTIFY_URL=https://api.hailin.com/api/pay/alipay/notify

# ==================== 其他配置 ====================
# 是否启用验证码
ENABLE_CAPTCHA=true

# 验证码长度
CAPTCHA_LENGTH=6

# 验证码过期时间（分钟）
CAPTCHA_EXPIRE_MINUTES=5

# 是否启用IP白名单
ENABLE_IP_WHITELIST=false

# IP白名单（逗号分隔）
IP_WHITELIST=127.0.0.1,192.168.1.1

# 是否启用限流
ENABLE_RATE_LIMIT=true

# 限流时间窗口（秒）
RATE_LIMIT_WINDOW=60

# 限流最大请求数
RATE_LIMIT_MAX_REQUESTS=100

# 是否启用CORS
ENABLE_CORS=true

# CORS允许的源
CORS_ORIGIN=https://hailin.com,https://www.hailin.com

# ==================== 测试环境专用 ====================
# 测试用户手机号
TEST_USER_PHONE=13800138000

# 测试用户密码
TEST_USER_PASSWORD=Test123456

# 测试订单号
TEST_ORDER_NO=TEST20240407001

# ==================== 说明 ====================
# 1. 此文件包含敏感信息，请勿提交到版本控制系统
# 2. 生产环境使用时，请将所有 'your_xxx_here' 替换为实际值
# 3. 部分配置项为可选，根据实际需求配置
# 4. 密钥类信息建议使用强随机字符串（至少32位）
# 5. 定期更换密钥和密码，提高安全性
